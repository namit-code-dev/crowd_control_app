<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".timeslot">

    <!-- TOOLBAR -->

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#D4FF5722"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="CROWD CONTROL"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/heartIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>


    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="365dp"
        android:layout_height="71dp"
        android:layout_marginBottom="16dp"
        android:background="#D4FF5722"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.4"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginHorizontal="10dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/home"
            tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

        <ImageButton
            android:id="@+id/btn1"
            android:layout_width="45dp"
            android:layout_height="36dp"
            android:layout_marginHorizontal="10dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/prasada"
            tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

        <ImageButton
            android:id="@+id/btn2"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_marginHorizontal="10dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/analysis"
            tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

        <ImageButton
            android:id="@+id/btn3"
            android:layout_width="40dp"
            android:layout_height="43dp"
            android:layout_marginHorizontal="10dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/tickets"
            tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

        <ImageButton
            android:id="@+id/btn4"
            android:layout_width="41dp"
            android:layout_height="43dp"
            android:layout_marginHorizontal="10dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/helpline"
            tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="358dp"
        android:layout_height="644dp"
        android:layout_marginEnd="2dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <TextView
            android:id="@+id/textView"
            android:layout_width="346dp"
            android:layout_height="39dp"
            android:layout_margin="5dp"
            android:gravity="center"
            android:text="SELECT YOUR SLOT"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CARD 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/c1"
                    android:layout_width="339dp"
                    android:layout_height="145dp"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="15dp"
                    app:cardBackgroundColor="#E2DDDD"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/t5"
                            android:layout_width="326dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="HURRY UP !!!!!!"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/t1"
                            android:layout_width="326dp"
                            android:layout_height="36dp"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/slot1"
                            android:layout_width="182dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />

                        <TextView
                            android:id="@+id/max1"
                            android:layout_width="185dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="MAX : 50000"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/c2"
                    android:layout_width="339dp"
                    android:layout_height="145dp"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="15dp"
                    app:cardBackgroundColor="#E2DDDD"
                    app:cardCornerRadius="15dp"

                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:id="@+id/t15"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        tools:ignore="DuplicateIds">

                        <TextView
                            android:id="@+id/t6"
                            android:layout_width="326dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="HURRY UP !!!!!!"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/t2"
                            android:layout_width="326dp"
                            android:layout_height="36dp"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/slot2"
                            android:layout_width="182dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />

                        <TextView
                            android:id="@+id/max2"
                            android:layout_width="185dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="MAX : 50000"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/c3"
                    android:layout_width="339dp"
                    android:layout_height="145dp"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="15dp"
                    app:cardBackgroundColor="#E2DDDD"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="136dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/t7"
                            android:layout_width="326dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="HURRY UP !!!!!!"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/t3"
                            android:layout_width="326dp"
                            android:layout_height="36dp"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/slot3"
                            android:layout_width="182dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />

                        <TextView
                            android:id="@+id/max3"
                            android:layout_width="185dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="MAX : 50000"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CARD 4 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/c4"
                    android:layout_width="339dp"
                    android:layout_height="145dp"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="15dp"
                    app:cardBackgroundColor="#E2DDDD"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="136dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/t8"
                            android:layout_width="326dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="HURRY UP !!!!!!"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/t4"
                            android:layout_width="326dp"
                            android:layout_height="36dp"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="center"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/slot4"
                            android:layout_width="182dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />

                        <TextView
                            android:id="@+id/max4"
                            android:layout_width="185dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="MAX : 50000"
                            android:textAlignment="textStart"
                            android:textColor="#DB2418"
                            android:textStyle="bold"
                            tools:ignore="RtlCompat" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>